# ============================================================
# Environment Variables — RAG System
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.
# ============================================================

# ── LLM Provider ──────────────────────────────────────────────
# Anthropic Claude (default provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT (alternative provider — set provider=openai in config/settings.yaml)
OPENAI_API_KEY=your_openai_api_key_here

# Cohere (optional — for Cohere Rerank instead of cross-encoder)
COHERE_API_KEY=your_cohere_api_key_here

# ── Optional Overrides ─────────────────────────────────────────
# Override config/settings.yaml values without editing the file.
# RAG_LOG_LEVEL=DEBUG
# RAG_CHROMA_DIR=./chroma_db
